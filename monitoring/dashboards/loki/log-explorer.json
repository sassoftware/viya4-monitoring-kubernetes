{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Loki-based log explorer with namespace, pod, and level filters. Displays trace_id in log lines for correlation with Tempo traces.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Log Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({namespace=~\"$namespace\"}[$__auto]))",
          "legendFormat": "{{namespace}}"
        }
      ],
      "title": "Log Volume by Namespace",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 3,
      "title": "Log Stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\", pod=~\"$pod\"} | json | level=~\"$level\" | line_format \"[{{.level}}] {{.message}}\"",
          "legendFormat": ""
        }
      ],
      "title": "Log Lines",
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "tags": ["loki", "logs", "sas-viya"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({}, namespace)",
        "name": "namespace",
        "query": { "query": "label_values({}, namespace)" },
        "refresh": 2,
        "type": "query",
        "includeAll": true,
        "multi": true
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({namespace=~\"$namespace\"}, pod)",
        "name": "pod",
        "query": { "query": "label_values({namespace=~\"$namespace\"}, pod)" },
        "refresh": 2,
        "type": "query",
        "includeAll": true,
        "multi": true
      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "name": "level",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "warn", "value": "warn" },
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "debug", "value": "debug" }
        ],
        "type": "custom",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Application Log Explorer (Loki)",
  "uid": "v4m-log-explorer",
  "version": 1
}
