{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Service overview with correlated metrics, logs, and traces using RED metrics from Tempo span_metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "RED Metrics (from Tempo span_metrics)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "auto" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{k8s_namespace_name=~\"$namespace\"}[$__rate_interval])) by (span_name)",
          "legendFormat": "{{span_name}}",
          "exemplar": true
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "auto" },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{k8s_namespace_name=~\"$namespace\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_calls_total{k8s_namespace_name=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Error Rate",
          "exemplar": true
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "auto" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{k8s_namespace_name=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "exemplar": true
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{k8s_namespace_name=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{k8s_namespace_name=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "exemplar": true
        }
      ],
      "title": "Duration Percentiles",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "title": "Logs (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "id": 6,
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\"} | json | line_format \"{{.message}}\"",
          "legendFormat": ""
        }
      ],
      "title": "Application Logs",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 7,
      "title": "Traces (Tempo)",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "id": 8,
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            { "id": "service-name", "tag": "resource.service.name", "operator": "=", "value": ["$service"], "valueType": "string" }
          ]
        }
      ],
      "title": "Recent Traces",
      "type": "traces"
    }
  ],
  "schemaVersion": 39,
  "tags": ["correlation", "lgtm", "sas-viya"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(kube_namespace_labels, namespace)",
        "name": "namespace",
        "query": { "query": "label_values(kube_namespace_labels, namespace)" },
        "refresh": 2,
        "type": "query",
        "includeAll": true,
        "multi": false
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(traces_spanmetrics_calls_total{k8s_namespace_name=~\"$namespace\"}, service)",
        "name": "service",
        "query": { "query": "label_values(traces_spanmetrics_calls_total{k8s_namespace_name=~\"$namespace\"}, service)" },
        "refresh": 2,
        "type": "query",
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Service Overview - Correlated Signals",
  "uid": "v4m-service-overview",
  "version": 1
}
