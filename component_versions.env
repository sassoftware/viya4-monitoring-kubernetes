#Elasticsearch Exporter — DEPRECATED (replaced by Alloy self-metrics via k8s-monitoring)
#ESEXPORTER_HELM_CHART_REPO=prometheus-community
#ESEXPORTER_HELM_CHART_NAME=prometheus-elasticsearch-exporter
#ESEXPORTER_HELM_CHART_VERSION=7.2.1
#ES_EXPORTER_FULL_IMAGE="quay.io/prometheuscommunity/elasticsearch-exporter:v1.10.0"

#Fluent Bit — DEPRECATED (replaced by Alloy via k8s-monitoring)
#FLUENTBIT_HELM_CHART_REPO=fluent
#FLUENTBIT_HELM_CHART_NAME=fluent-bit
#FLUENTBIT_HELM_CHART_VERSION=0.56.0
#FB_FULL_IMAGE="cr.fluentbit.io/fluent/fluent-bit:4.2.3"
#FB_INITCONTAINER_FULL_IMAGE="docker.io/library/busybox:latest"

#OpenSearch
OPENSEARCH_HELM_CHART_REPO=opensearch
OPENSEARCH_HELM_CHART_NAME=opensearch
OPENSEARCH_HELM_CHART_VERSION=3.4.0
OS_FULL_IMAGE="docker.io/opensearchproject/opensearch:3.4.0"
OS_SYSCTL_FULL_IMAGE="docker.io/library/busybox:latest"

#OpenSearch Dashboards
OSD_HELM_CHART_REPO=opensearch
OSD_HELM_CHART_NAME=opensearch-dashboards
OSD_HELM_CHART_VERSION=3.4.0
OSD_FULL_IMAGE="docker.io/opensearchproject/opensearch-dashboards:3.4.0"

#Grafana (when deployed on OpenShift)
OPENSHIFT_GRAFANA_CHART_REPO=grafana-community
OPENSHIFT_GRAFANA_CHART_NAME=grafana
OPENSHIFT_GRAFANA_CHART_VERSION=11.0.1
OPENSHIFT_OAUTHPROXY_FULL_IMAGE="registry.redhat.io/openshift4/ose-oauth-proxy:latest"

#Grafana (everywhere)
GRAFANA_FULL_IMAGE="docker.io/grafana/grafana:12.3.2"
GRAFANA_SIDECAR_FULL_IMAGE="quay.io/kiwigrid/k8s-sidecar:2.5.0"
GRAFANA_DATASOURCE_PLUGIN_VERSION="2.32.6"

#Prometheus (standalone server + alertmanager)
PROMETHEUS_CHART_REPO=prometheus-community
PROMETHEUS_CHART_NAME=prometheus
PROMETHEUS_CHART_VERSION=29.2.1
PROMETHEUS_FULL_IMAGE="quay.io/prometheus/prometheus:v3.11.2"
ALERTMANAGER_FULL_IMAGE="quay.io/prometheus/alertmanager:v0.28.1"

#Grafana (standalone)
GRAFANA_CHART_REPO=grafana-community
GRAFANA_CHART_NAME=grafana
GRAFANA_CHART_VERSION=11.6.1

#Pushgateway
PUSHGATEWAY_CHART_REPO=prometheus-community
PUSHGATEWAY_CHART_NAME=prometheus-pushgateway
PUSHGATEWAY_CHART_VERSION=3.6.0
PUSHGATEWAY_FULL_IMAGE="quay.io/prometheus/pushgateway:v1.11.2"

#Prometheus Operator CRD
##NOTE: PROM_OPERATOR_CRD_VERSION is now automatically
##      set to match the Prometheus Operator version.
##      However, it can still be set explicitly if need be.

#Tempo
TEMPO_CHART_REPO=grafana-community
TEMPO_CHART_NAME=tempo
TEMPO_CHART_VERSION=1.24.1
TEMPO_FULL_IMAGE="docker.io/grafana/tempo:2.9.0"

#Grafana k8s-monitoring (Alloy-based collection)
K8S_MONITORING_CHART_REPO=grafana
K8S_MONITORING_CHART_NAME=k8s-monitoring
K8S_MONITORING_CHART_VERSION=4.0.1

#Grafana Loki (log storage)
LOKI_CHART_REPO=grafana-community
LOKI_CHART_NAME=loki
LOKI_CHART_VERSION=6.29.0
LOKI_FULL_IMAGE="docker.io/grafana/loki:3.5.0"

#OTel Collector (OpenSearch gateway)
OTEL_COLLECTOR_FULL_IMAGE="docker.io/otel/opentelemetry-collector-contrib:0.114.0"
